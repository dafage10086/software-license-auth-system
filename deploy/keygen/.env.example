# Copy to .env for a private deployment and replace every placeholder.

POSTGRES_USER=license_auth_example
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_DB=license_auth_example
REDIS_URL=redis://redis:6379

CLICKHOUSE_USER=license_analytics_example
CLICKHOUSE_PASSWORD=CHANGE_ME_CLICKHOUSE_PASSWORD
CLICKHOUSE_DB=license_auth_example
CLICKHOUSE_DATABASE_URL=CHANGE_ME_CLICKHOUSE_URL
CLICKHOUSE_DATABASE_ENABLED=1
CLICKHOUSE_TLS_DISABLED=1

SECRET_KEY_BASE=CHANGE_ME_WITH_128_HEX_CHARS
ENCRYPTION_DETERMINISTIC_KEY=CHANGE_ME_WITH_BASE64_32_BYTES
ENCRYPTION_PRIMARY_KEY=CHANGE_ME_WITH_BASE64_32_BYTES
ENCRYPTION_KEY_DERIVATION_SALT=CHANGE_ME_WITH_BASE64_32_BYTES

KEYGEN_EDITION=CE
KEYGEN_MODE=singleplayer
KEYGEN_ACCOUNT_ID=CHANGE_ME_LOWERCASE_UUID
KEYGEN_ADMIN_EMAIL=EXAMPLE_ADMIN_EMAIL
KEYGEN_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
KEYGEN_HOST=EXAMPLE_LICENSE_HOST
KEYGEN_HOSTS=EXAMPLE_ADDITIONAL_LICENSE_HOSTS

RAILS_LOG_TO_STDOUT=1
RAILS_MAX_THREADS=5
SIDEKIQ_CONCURRENCY=5
